# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Production builds
dist/
build/
out/

# TypeScript compilation output (be specific to avoid ignoring config files)
/backend/src/**/*.js
/backend/src/**/*.js.map
/backend/src/**/*.d.ts
/backend/src/**/*.d.ts.map
/frontend/src/**/*.js
/frontend/src/**/*.js.map
/frontend/src/**/*.d.ts
/frontend/src/**/*.d.ts.map

# Keep essential JS config files
!**/eslint.config.js
!**/postcss.config.js
!**/tailwind.config.js
!**/vite.config.js
!**/vitest.config.js
!y-websocket-server/**/*.js

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Database
*.db
*.sqlite
*.sqlite3
database.db

# Prisma
# Keep schema.prisma and migrations, but ignore generated client
/backend/prisma/generated/
/backend/node_modules/.prisma/

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# VS Code
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
.vscode/tasks.json
# Keep workspace settings but ignore user-specific ones
!.vscode/settings.json.example

# IDEs
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
*.lnk

# Temporary folders
tmp/
temp/

# Package manager lock files (you can uncomment if you want to track them)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Vite
.vite/

# TipTap/Editor specific
.tiptap-cache/

# Local uploads/assets (if any)
uploads/
public/uploads/

# Backup files
*.backup
*.bak

# Test artifacts
test-results/
playwright-report/
playwright/.cache/

# Local development
.local

# Workspace specific ignores
# Add any project-specific files/folders here